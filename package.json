{
  "name": "notes-sticker-pwa",
  "version": "1.0.4-beta.0",
  "description": "App desktop personale per note ricche e personalizzabili.",
  "author": "@jacofrau su Instagram",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000 --webpack",
    "build": "next build --webpack",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint .",
    "runtime:env": "node ./scripts/sync-runtime-env.cjs",
    "installer:assets": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-installer-assets.ps1",
    "desktop:dev": "electron .",
    "desktop:build": "npm run desktop:build:win",
    "desktop:build:win": "npm run runtime:env && npm run installer:assets && npm run build && node ./scripts/run-electron-builder.cjs --win nsis",
    "desktop:build:mac": "npm run runtime:env && npm run build && node ./scripts/run-electron-builder.cjs --mac dmg zip",
    "desktop:build:mac:universal": "npm run runtime:env && npm run build && node ./scripts/run-electron-builder.cjs --mac dmg zip --universal",
    "desktop:installer": "npm run desktop:build:win",
    "desktop:release:zip": "powershell -ExecutionPolicy Bypass -File ./scripts/package-release.ps1",
    "desktop:release": "npm run desktop:installer && powershell -ExecutionPolicy Bypass -File ./scripts/package-release.ps1",
    "desktop:release:mac": "npm run desktop:build:mac",
    "desktop:unpacked": "npm run runtime:env && npm run build && node ./scripts/run-electron-builder.cjs --win dir",
    "desktop:portable": "npm run runtime:env && npm run build && node ./scripts/run-electron-builder.cjs --win portable"
  },
  "build": {
    "appId": "com.jaco.notes",
    "productName": "Note",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "it",
      "en-US"
    ],
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json",
      "next.config.js",
      "!**/.next/cache/**",
      "!**/.next/dev/**",
      "!**/.next/diagnostics/**",
      "!**/*.map",
      "!**/.next/types/**",
      "!**/.next/trace",
      "!**/.next/trace-build"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "icon": "public/icons/notedijaco_icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Note",
      "uninstallDisplayName": "Note",
      "installerHeader": "build/installerHeader.bmp",
      "installerIcon": "public/icons/notedijaco_icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerIcon": "public/icons/notedijaco_icon.ico",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "installerHeaderIcon": "public/icons/notedijaco_icon.ico"
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@supabase/supabase-js": "^2.98.0",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "idb-keyval": "^6.2.1",
    "jszip": "^3.10.1",
    "nanoid": "^5.0.7",
    "next": "^16.2.1",
    "nodemailer": "^8.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.14",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "typescript": "5.9.3"
  }
}
