# Azure Trusted Signing configuration for electron-builder
# Fill these values in your local environment before running a signed desktop build.

# Azure authentication (EnvironmentCredential / service principal)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Trusted Signing profile
AZURE_TRUSTED_SIGNING_ENDPOINT=
AZURE_TRUSTED_SIGNING_ACCOUNT_NAME=
AZURE_TRUSTED_SIGNING_CERTIFICATE_PROFILE_NAME=
AZURE_TRUSTED_SIGNING_PUBLISHER_NAME=
